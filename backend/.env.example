APP_NAME=Rotom Agent
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+asyncpg://ALPHA:rotom_dev_password@postgres:5432/rotom_agent

RABBITMQ_URL=amqp://ALPHA:rotom_dev_password@rabbitmq:5672/
RABBITMQ_QUEUE=agent_runs

ZHIPU_API_KEY=replace-with-your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4.5-air

WORKSPACE_ROOT=/app/storage/workspaces
